# ---- Core ----
NODE_ENV=development
PORT=5000
# Public base URL for OAuth redirects (no trailing slash).
# Local: http://localhost:5000   Prod: https://your-app.onrender.com
PUBLIC_URL=http://localhost:5000

# ---- Database (Neon Postgres) ----
# Get from https://console.neon.tech/ -> your project -> Connection Details
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# ---- Session ----
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-64-char-random-hex

# ---- Google OAuth ----
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match: <PUBLIC_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- AI Providers ----
ANTHROPIC_API_KEY=
REPLICATE_API_TOKEN=

# ---- Payments (optional - subscriptions hidden in v1) ----
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
